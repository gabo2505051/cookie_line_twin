    "func": "var p = msg.payload;\nif (p.state === 'fault')   node.warn('⚠ FALLA M1 Mezcladora: ' + p.alarm);\nif (p.state === 'startup') node.log('🔄 ARRANQUE M1 Mezcladora');\nmsg.topic   = 'M1-' + p.state;\nmsg.payload = p.speed_pct;\nreturn msg;",
