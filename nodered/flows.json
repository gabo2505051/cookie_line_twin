  {
    "id": "extract-oee",
    "type": "function",
    "z": "tab-cookie-oee",
    "name": "Extraer OEE",
    "func": "var p = msg.payload;\n\nflow.set('oee', p.oee);\nflow.set('shift_number', p.shift_number);\n\n// Gauge OEE\nmsg.payload = p.oee;\nmsg.topic   = 'OEE %';\nreturn msg;",
    "outputs": 1,
    "x": 600,
    "y": 40,
    "wires": [
      [
        "gauge-oee",
        "chart-oee"
      ]
    ]
  },
