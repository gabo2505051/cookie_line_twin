    "name": "M4 Horno",
    "func": "var p = msg.payload;\nif (p.state === 'fault')   node.warn('⚠ FALLA M4 Horno: ' + p.alarm);\nif (p.state === 'startup') node.log('🔄 ARRANQUE M4 Horno');\n\nvar speedMsg = { payload: p.speed_pct, topic: 'M4-' + p.state };\nvar tempMsg  = { payload: p.temperature_c, topic: 'Temperatura' };\n\n// Desviación de temperatura: enviar al chart de tendencia\nvar deviationMsg = { payload: p.temp_deviation || 0, topic: 'Desviación °C' };\n\nreturn [ speedMsg, tempMsg, deviationMsg ];",
