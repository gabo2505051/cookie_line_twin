  {
    "id": "extract-summary",
    "type": "function",
    "z": "tab-cookie-oee",
    "name": "Extraer resumen línea",
    "func": "var p = msg.payload;\n\n// ── Etiquetas de estado ───────────────────────────────────────────\nvar stateLabel = {\n  running: '▶  CORRIENDO',\n  fault:   '⚠  FALLA',\n  stopped: '⏹  DETENIDA',\n  startup: '🔄  ARRANQUE'\n};\n\n// Output 1: estado general de la línea\nvar stateMsg = { payload: stateLabel[p.line_state] || p.line_state };\n\n// Output 2 y 3: producción acumulada y rechazos para el chart\nvar producedMsg = { payload: p.total_produced, topic: 'Producidas' };\nvar rejectedMsg = { payload: p.total_rejected, topic: 'Rechazadas' };\n\n// Output 4: detalle de falla o arranque\nvar detailText = '— Sin alertas activas —';\nif (p.fault_details && p.fault_details.length > 0) {\n  detailText = p.fault_details.map(function(f) {\n    return '⚠ ' + f.name + ' (' + f.machine + ') → ' + f.alarm;\n  }).join('  |  ');\n} else if (p.machines_starting && p.machines_starting.length > 0) {\n  detailText = '🔄 Arrancando: ' + p.machines_starting.join(', ');\n}\nvar detailMsg = { payload: detailText };\n\n// Output 5: tasa de merma %\nvar rejectMsg = { payload: parseFloat((p.reject_rate_pct || 0).toFixed(2)) };\n\nreturn [ stateMsg, producedMsg, rejectedMsg, detailMsg, rejectMsg ];",
    "outputs": 5,
    "x": 620,
    "y": 180,
    "wires": [
      [
        "text-line-state"
      ],
      [
        "chart-production"
      ],
      [
        "chart-production"
      ],
      [
        "text-fault-detail"
      ],
      [
        "gauge-reject-rate"
      ]
    ]
  },
